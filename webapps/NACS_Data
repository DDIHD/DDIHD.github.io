<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NACS_Data</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        #tab-agent.active { display: flex; }
        /* Custom scrollbar for chat */
        #chat-container::-webkit-scrollbar { width: 8px; }
        #chat-container::-webkit-scrollbar-track { background: #f1f1f1; }
        #chat-container::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 4px; }
        
        .chat-bubble-user { background-color: #e0f2fe; color: #075985; border-radius: 1rem 1rem 0 1rem; padding: 0.75rem; max-width: 80%; margin-left: auto; margin-bottom: 0.5rem; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        .chat-bubble-bot { background-color: #ffffff; color: #1f2937; border-radius: 1rem 1rem 1rem 0; padding: 0.75rem; max-width: 80%; margin-right: auto; margin-bottom: 0.5rem; border: 1px solid #e5e7eb; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        
        /* Disabled button style */
        .btn-disabled { opacity: 0.5; cursor: not-allowed; background-color: #9ca3af; }
    </style>
</head>
<body class="bg-gray-100 h-screen flex flex-col">

    <nav class="bg-blue-900 text-white shadow-lg z-10">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <div class="text-xl font-bold tracking-tight">NACS_<span class="text-blue-400">Data</span></div>
            <div class="space-x-1 md:space-x-4">
                <button onclick="switchTab('quellen')" class="tab-btn px-4 py-2 rounded transition-colors duration-200 font-medium active-tab bg-blue-800 border border-blue-700">Datenquellen</button>
                <button onclick="switchTab('aufgabe')" class="tab-btn px-4 py-2 rounded transition-colors duration-200 hover:bg-blue-800 font-medium border border-transparent">Wöchentliche Aufgabe</button>
                <button onclick="switchTab('agent')" class="tab-btn px-4 py-2 rounded transition-colors duration-200 hover:bg-blue-800 font-medium border border-transparent">Sprachagent</button>
            </div>
        </div>
    </nav>

    <div class="flex-grow container mx-auto px-4 py-6 overflow-hidden flex flex-col">

        <div id="tab-quellen" class="tab-content active h-full overflow-y-auto">
            <h2 class="text-3xl font-bold text-gray-800 mb-8">Verfügbare Umweltdaten</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
                    <div class="bg-green-600 h-2 w-full"></div>
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-4">
                            <h3 class="text-xl font-bold text-gray-800">Atmosphärisches CO₂</h3>
                            <span class="bg-green-100 text-green-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Global</span>
                        </div>
                        <p class="text-gray-600 text-sm leading-relaxed mb-6">Monatliche Mittelwerte der CO₂-Konzentrationen, gemessen am Mauna Loa Observatorium, Hawaii. Dieser Datensatz ist der weltweite Standard ("Keeling Curve"), um den Anstieg von Treibhausgasen seit 1958 zu verfolgen.</p>
                        
                        <div class="bg-gray-50 rounded p-4 text-xs space-y-2 border border-gray-100">
                            <div class="flex justify-between"><span class="font-semibold text-gray-500">QUELLE</span> <span class="text-gray-900">NOAA Global Monitoring Laboratory</span></div>
                            <div class="flex justify-between"><span class="font-semibold text-gray-500">LIZENZ</span> <span class="text-gray-900">Public Domain (U.S. Gov)</span></div>
                            <div class="flex justify-between"><span class="font-semibold text-gray-500">FORMAT</span> <span class="text-gray-900 font-mono">CSV / Text</span></div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
                    <div class="bg-blue-600 h-2 w-full"></div>
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-4">
                            <h3 class="text-xl font-bold text-gray-800">Lufttemperatur Berlin</h3>
                            <span class="bg-blue-100 text-blue-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Lokal</span>
                        </div>
                        <p class="text-gray-600 text-sm leading-relaxed mb-6">Historische monatliche Lufttemperaturen der Station Berlin-Dahlem. Einer der längsten durchgehenden Klimadatensätze weltweit (Messungen seit 1719), der lokale Klimaveränderungen dokumentiert.</p>
                        
                        <div class="bg-gray-50 rounded p-4 text-xs space-y-2 border border-gray-100">
                            <div class="flex justify-between"><span class="font-semibold text-gray-500">QUELLE</span> <span class="text-gray-900">Deutscher Wetterdienst (DWD)</span></div>
                            <div class="flex justify-between"><span class="font-semibold text-gray-500">LIZENZ</span> <a href="#" class="text-blue-600 hover:text-blue-800 underline">CC BY 4.0</a></div>
                            <div class="flex justify-between"><span class="font-semibold text-gray-500">FORMAT</span> <span class="text-gray-900 font-mono">ZIP / CSV (Semikolon-getrennt)</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-aufgabe" class="tab-content h-full overflow-y-auto">
            <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="p-8">
                    <div class="flex items-center space-x-3 mb-6">
                        <div class="bg-blue-100 p-2 rounded-full text-blue-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-gray-800">Aufgabe 3: Mustererkennung</h2>
                    </div>
                    
                    <p class="text-gray-600 mb-6 text-lg">Schau dir die Grafik der CO₂-Konzentration genau an. Du siehst einen stetigen Anstieg, aber auch ein ständiges Auf und Ab.</p>
                    
                    <div class="border rounded-lg p-2 bg-gray-50 mb-8 shadow-inner">
                        <div id="co2-plot" class="w-full h-96"></div>
                    </div>
                    
                    <div class="bg-blue-50 border-l-4 border-blue-500 p-6 rounded-r">
                        <h4 class="text-blue-900 font-bold mb-2">Deine Aufgabe:</h4>
                        <p class="mb-4 text-blue-800">Warum zeigt der Graph ein solches "Sägezahn"-Muster, das sich jedes Jahr wiederholt? Was passiert in der Natur im Frühling und im Herbst, das den CO₂-Gehalt beeinflusst?</p>
                        
                        <div class="mt-4">
                            <div class="w-full h-32 bg-white border border-blue-200 rounded p-4 text-gray-400 italic">
                                Hier würde dein Text stehen (Editor im Mockup deaktiviert)...
                            </div>
                            <div class="mt-4 flex justify-end">
                                <button class="btn-disabled text-white font-bold py-2 px-6 rounded shadow" disabled>
                                    Antwort hochladen
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-agent" class="tab-content h-full flex-col">
            <div class="bg-white rounded-lg shadow-xl flex flex-col h-full relative overflow-hidden border border-gray-200">
                
                <div id="agent-banner" class="bg-green-600 text-white px-6 py-4 font-bold flex justify-between items-center shadow-md z-20 transition-all duration-500">
                    <div class="flex items-center space-x-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
                        <span id="banner-text">Modus: Natürliche Sprache</span>
                    </div>
                    <span id="level-badge" class="text-xs font-bold bg-white/25 px-3 py-1 rounded-full uppercase tracking-wider border border-white/30">Level 1</span>
                </div>

                <div id="chat-container" class="flex-grow overflow-y-auto p-6 space-y-6 bg-gray-50 scroll-smooth">
                    <div class="chat-bubble-bot shadow-sm">
                        Hallo! Ich bin dein Daten-Assistent. Ich habe Zugriff auf die DWD (Berlin) und NOAA (Global CO₂) Datenbanken. Was möchtest du wissen?
                    </div>
                </div>

                <div class="p-4 bg-white border-t border-gray-200 z-20">
                    <div id="controls-area" class="flex flex-col gap-2">
                        <button onclick="handleStep(1)" class="w-full text-left bg-white hover:bg-gray-50 text-gray-800 font-medium py-3 px-4 rounded border border-gray-300 shadow-sm transition-all hover:shadow-md flex items-center justify-between group">
                            <span>Was war der heißeste Monat in Berlin seit Aufzeichnungsbeginn?</span>
                            <span class="text-gray-400 group-hover:text-blue-500">➜</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        // --- 1. DATA GENERATION (Simulating Backend) ---
        
        // Helper to format float year to "YYYY.M" for cleaner hover
        function formatYearDecimal(val) {
            return val.toFixed(1);
        }

        // CO2 Data (Simulated Sawtooth)
        const co2Dense = [];
        for (let y = 1960; y < 2024; y += 0.083) { 
            let trend = 315 + (y - 1960) * 1.6 + Math.pow((y-1960)/60, 2)*15;
            let seasonal = Math.sin(2 * Math.PI * y) * 3; 
            co2Dense.push({x: y, y: trend + seasonal});
        }

        // Berlin Data (Full History for Scaffolding)
        const berlinData = [];
        // Generate monthly data from 1750 to 2023
        for (let y = 1750; y <= 2023; y++) {
            let avg = 9 + (y > 1900 ? (y-1900)*0.015 : 0) + (Math.random() - 0.5)*1.5; 
            for(let m=0; m<12; m++) {
                // Seasonal curve + noise
                let temp = avg + Math.sin(((m-3)/12)*2*Math.PI) * 10 + ((Math.random()-0.5)*3);
                
                // Inject the specific fact to ensure consistency
                if(y===1757 && m===6) temp = 24.3; 
                
                // Format decimal date for plotting (e.g., 1750.5) and string for tooltip
                berlinData.push({
                    year: y,
                    decimal: y + (m/12),
                    temp: parseFloat(temp.toFixed(1)),
                    dateStr: `${(m+1).toString().padStart(2,'0')}/${y}`
                });
            }
        }

        // Correlation Data (Mastery) - Scatter
        // Create realistic scatter: X=CO2, Y=Temp (Annual Avg)
        const correlationData = [];
        let currentCo2 = 315;
        for (let y = 1960; y <= 2023; y++) {
            currentCo2 += 1.5 + (Math.random()*0.5); // CO2 rises
            let temp = 9.0 + ((currentCo2 - 315)/100)*1.5 + (Math.random()-0.5); // Temp correlated with CO2 + noise
            correlationData.push({x: currentCo2, y: temp, year: y});
        }


        // --- 2. APP FUNCTIONS ---

        function switchTab(tabId) {
            // UI Toggle
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.classList.remove('bg-blue-800', 'active-tab', 'border-blue-700');
                el.classList.add('border-transparent', 'hover:bg-blue-800');
            });
            
            document.getElementById('tab-' + tabId).classList.add('active');
            const activeBtn = Array.from(document.querySelectorAll('.tab-btn')).find(el => el.getAttribute('onclick').includes(tabId));
            activeBtn.classList.add('bg-blue-800', 'active-tab', 'border-blue-700');
            activeBtn.classList.remove('border-transparent', 'hover:bg-blue-800'); // Keep solid blue

            // Trigger resize for plots when tab becomes visible
            if (tabId === 'aufgabe') {
                setTimeout(() => renderCo2Chart(), 50);
            }
        }

        function renderCo2Chart() {
            const trace = {
                x: co2Dense.map(d => d.x),
                y: co2Dense.map(d => d.y),
                mode: 'lines',
                line: {color: '#dc2626', width: 1.5},
                name: 'CO2',
                hovertemplate: 'Jahr: %{x:.1f}<br>CO2: %{y:.1f} ppm<extra></extra>' // Custom hover format
            };
            
            const layout = {
                title: {text: 'Mauna Loa CO₂ Konzentration (1960-2023)', font: {size: 14}},
                xaxis: {title: 'Jahr', tickformat: 'd'}, // Integer ticks
                yaxis: {title: 'CO₂ (ppm)'},
                margin: {t: 40, b: 40, l: 50, r: 20},
                paper_bgcolor: 'rgba(0,0,0,0)',
                plot_bgcolor: 'rgba(0,0,0,0)',
                hovermode: 'closest'
            };
            
            Plotly.newPlot('co2-plot', [trace], layout, {responsive: true, displayModeBar: false});
        }

        // --- 3. AGENT STATE MACHINE ---

        const chatContainer = document.getElementById('chat-container');
        const controlsArea = document.getElementById('controls-area');
        const banner = document.getElementById('agent-banner');
        const bannerText = document.getElementById('banner-text');
        const levelBadge = document.getElementById('level-badge');

        function addMessage(text, isUser) {
            const div = document.createElement('div');
            div.className = isUser ? 'chat-bubble-user' : 'chat-bubble-bot';
            div.innerHTML = text;
            chatContainer.appendChild(div);
            // Scroll to bottom smoothly
            setTimeout(() => {
                chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
            }, 50);
        }

        // Scaffolding State Variables
        let scaffoldStartYear = 1750;
        let scaffoldTopN = 10;

        // Function called by inputs to update graph live
        function updateScaffoldChart() {
            // 1. Get values
            const slider = document.getElementById('year-slider');
            const numInput = document.getElementById('top-n-input');
            if(!slider || !numInput) return; // Guard clause

            scaffoldStartYear = parseInt(slider.value);
            scaffoldTopN = parseInt(numInput.value);

            // Update Label
            document.getElementById('year-val').innerText = `${scaffoldStartYear} - 2023`;

            // 2. Filter Data
            const filteredData = berlinData.filter(d => d.year >= scaffoldStartYear);
            
            // 3. Find Top N in filtered range
            // Clone array to sort safely
            const sorted = [...filteredData].sort((a,b) => b.temp - a.temp);
            const topN = sorted.slice(0, scaffoldTopN);
            
            // 4. Update Plot
            const traceLine = {
                x: filteredData.map(d => d.decimal),
                y: filteredData.map(d => d.temp),
                type: 'scatter',
                mode: 'lines',
                line: {color: '#94a3b8', width: 0.5},
                hoverinfo: 'none' // Disable hover on the noisy line to prioritize dots
            };

            const traceMarkers = {
                x: topN.map(d => d.decimal),
                y: topN.map(d => d.temp),
                mode: 'markers',
                marker: {color: '#ef4444', size: 6, opacity: 0.8},
                hovertemplate: 'Datum: %{text}<br>Temp: %{y:.1f}°C<extra></extra>',
                text: topN.map(d => d.dateStr)
            };

            const layout = {
                xaxis: {title: 'Jahr', tickformat: 'd'},
                yaxis: {title: 'Temperatur (°C)'},
                margin: {t: 20, b: 30, l: 40, r: 10},
                showlegend: false,
                height: 250 // Force height inside chat
            };

            Plotly.react('scaffold-chart', [traceLine, traceMarkers], layout, {displayModeBar: false});
        }


        function handleStep(actionId) {
            if (actionId === 1) { // User asks
                addMessage("Was war der heißeste Monat in Berlin seit Aufzeichnungsbeginn?", true);
                controlsArea.innerHTML = ''; // Clear buttons
                
                setTimeout(() => {
                    addMessage("Basierend auf dem DWD-Datensatz war der heißeste Monat der <strong>Juli 1757</strong> mit einer Durchschnittstemperatur von <strong>24.3°C</strong>.", false);
                    
                    setTimeout(() => {
                        controlsArea.innerHTML = `
                        <button onclick="handleStep(2)" class="w-full text-left bg-white hover:bg-gray-50 text-gray-800 font-medium py-3 px-4 rounded border border-gray-300 shadow-sm transition-all hover:shadow-md flex items-center justify-between group">
                            <span>Visualisiere den Temperaturverlauf in Berlin und hebe die 10 heißesten Monate hervor.</span>
                            <span class="text-gray-400 group-hover:text-blue-500">➜</span>
                        </button>`;
                    }, 500);
                }, 600);
            }
            else if (actionId === 2) { // Visualize (First Graph)
                addMessage("Visualisiere den Temperaturverlauf in Berlin und hebe die 10 heißesten Monate hervor.", true);
                controlsArea.innerHTML = '';

                setTimeout(() => {
                    addMessage("Hier ist die Visualisierung der monatlichen Durchschnittstemperaturen seit 1750:", false);
                    
                    // Create container with FIXED height to prevent flatness
                    const chartId = 'chat-chart-1';
                    const chartDiv = document.createElement('div');
                    chartDiv.id = chartId;
                    chartDiv.className = "w-full bg-white border rounded mt-2 shadow-sm";
                    chartDiv.style.height = "300px"; // Explicit height
                    chatContainer.appendChild(chartDiv);
                    
                    // Initial Plot Data (Full range, Top 10)
                    const top10 = [...berlinData].sort((a,b) => b.temp - a.temp).slice(0, 10);
                    
                    const trace1 = { 
                        x: berlinData.map(d=>d.decimal), 
                        y: berlinData.map(d=>d.temp), 
                        type: 'scatter', 
                        mode: 'lines', 
                        line: {color: '#cbd5e1', width: 0.5},
                        hoverinfo: 'none'
                    };
                    const trace2 = { 
                        x: top10.map(d=>d.decimal), 
                        y: top10.map(d=>d.temp), 
                        mode: 'markers', 
                        marker: {color: '#ef4444', size: 6}, 
                        hovertemplate: 'Datum: %{text}<br>Temp: %{y:.1f}°C<extra></extra>',
                        text: top10.map(d=>d.dateStr)
                    };
                    
                    Plotly.newPlot(chartId, [trace1, trace2], { 
                        margin: {t:20,b:30,l:40,r:10}, 
                        showlegend: false,
                        xaxis: {tickformat: 'd'}
                    }, {responsive:true, displayModeBar: false});
                    
                    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });

                    setTimeout(() => {
                        controlsArea.innerHTML = `
                        <button onclick="handleStep(3)" class="w-full text-center bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-bold py-3 px-4 rounded border border-indigo-200 shadow-sm transition-all">
                            🛠️ Modus wechseln: "Scaffolding"
                        </button>`;
                    }, 800);

                }, 800);
            }
            else if (actionId === 3) { // Scaffolding Switch
                addMessage("<i>Wechsle zu Scaffolding Modus...</i>", true);
                controlsArea.innerHTML = '';
                
                // Animate Banner
                banner.classList.remove('bg-green-600');
                banner.classList.add('bg-blue-600');
                bannerText.innerText = "Modus: Scaffolding";
                levelBadge.innerText = "Level 2";
                
                setTimeout(() => {
                    addMessage("Ich habe die Visualisierung angepasst. Du kannst nun Parameter verändern, um die Daten zu erkunden.", false);
                    
                    // Create Interactive UI Container
                    const uiDiv = document.createElement('div');
                    uiDiv.className = "bg-white p-4 rounded-lg border border-blue-200 shadow-sm mt-2";
                    uiDiv.innerHTML = `
                        <div class="flex flex-col md:flex-row gap-4 mb-4 text-sm">
                            <div class="flex-1">
                                <label class="block text-gray-600 font-bold mb-1">Startjahr: <span id="year-val" class="text-blue-600">1750 - 2023</span></label>
                                <input id="year-slider" type="range" min="1750" max="2000" value="1750" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-600" oninput="updateScaffoldChart()">
                            </div>
                            <div class="w-32">
                                <label class="block text-gray-600 font-bold mb-1">Top Monate:</label>
                                <input id="top-n-input" type="number" min="1" max="50" value="10" class="w-full border rounded px-2 py-1 focus:ring-2 focus:ring-blue-500 outline-none" oninput="updateScaffoldChart()">
                            </div>
                        </div>
                        <div id="scaffold-chart" style="height: 250px;"></div>
                    `;
                    chatContainer.appendChild(uiDiv);
                    
                    // Render initial scaffold chart
                    // Use a timeout to ensure DOM element exists
                    setTimeout(updateScaffoldChart, 50);
                    
                    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });

                    setTimeout(() => {
                        controlsArea.innerHTML = `
                        <button onclick="handleStep(4)" class="w-full text-center bg-purple-50 hover:bg-purple-100 text-purple-700 font-bold py-3 px-4 rounded border border-purple-200 shadow-sm transition-all">
                            🚀 Modus wechseln: "Mastery"
                        </button>`;
                    }, 1000);

                }, 600);
            }
            else if (actionId === 4) { // Mastery Mode
                addMessage("<i>Wechsle zu Mastery Modus...</i>", true);
                controlsArea.innerHTML = '';
                
                banner.classList.remove('bg-blue-600');
                banner.classList.add('bg-purple-700');
                bannerText.innerText = "Modus: Mastery";
                levelBadge.innerText = "Level 3";

                setTimeout(() => {
                    addMessage("Im Mastery-Modus hast du volle Kontrolle. Verbinde die CO₂-Daten mit den Temperaturdaten, um Korrelationen zu finden. Ein Python-Snippet wurde vorbereitet, welches zwei Datenquellen verbindet.", false);

                    // Code Editor Mock
                    const codeEditor = document.createElement('div');
                    codeEditor.className = "w-full mt-2 rounded-lg overflow-hidden shadow-lg border border-gray-700";
                    codeEditor.innerHTML = `
                        <div class="bg-gray-800 text-gray-300 text-xs px-4 py-2 font-mono flex justify-between items-center">
                            <span>main.py</span>
                            <span class="text-green-400">● Ready</span>
                        </div>
                        <textarea class="w-full h-32 bg-gray-900 text-gray-100 font-mono text-xs p-4 focus:outline-none resize-none" spellcheck="false">
import pandas as pd
# Lade Datensätze
df_co2 = load("co2_mlo.csv")
df_temp = load("berlin_temp.csv")

# Merge auf Jahresbasis
merged = pd.merge(df_co2, df_temp, on='year')

# Scatter Plot: x=CO2, y=Temp
plot(x=merged['co2'], y=merged['temp'], type='scatter')</textarea>
                        <div class="bg-gray-800 p-2">
                            <button onclick="handleStep(5)" class="bg-green-600 hover:bg-green-500 text-white font-bold py-1 px-4 rounded text-sm flex items-center gap-2 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" /></svg>
                                Code ausführen
                            </button>
                        </div>
                    `;
                    chatContainer.appendChild(codeEditor);
                    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
                }, 600);
            }
            else if (actionId === 5) { // Run Code
                // Disable button to prevent double click (simulated by just adding message)
                addMessage("<code>> Executing script...</code>", true);
                
                setTimeout(() => {
                    addMessage("Code erfolgreich ausgeführt. Grafik generiert:", false);
                    
                    const chartId = 'mastery-chart';
                    const chartDiv = document.createElement('div');
                    chartDiv.id = chartId;
                    chartDiv.className = "w-full bg-white border rounded mt-2 shadow-md";
                    chartDiv.style.height = "320px";
                    chatContainer.appendChild(chartDiv);

                    // SCATTER PLOT FIX
                    const trace = {
                        x: correlationData.map(d=>d.x),
                        y: correlationData.map(d=>d.y),
                        mode: 'markers',
                        marker: { 
                            size: 8, 
                            color: correlationData.map(d=>d.year), // Color by year
                            colorscale: 'Viridis',
                            showscale: true,
                            colorbar: {title: 'Jahr', thickness: 10}
                        },
                        hovertemplate: 'CO2: %{x:.1f} ppm<br>Temp: %{y:.1f}°C<br>Jahr: %{marker.color}<extra></extra>',
                        type: 'scatter'
                    };
                    
                    const layout = {
                        title: 'Korrelation: CO₂ (Global) vs. Temperatur (Berlin)',
                        xaxis: {title: 'Atmosphärisches CO₂ (ppm)', range: [310, 430]},
                        yaxis: {title: 'Jahresmitteltemperatur (°C)', range: [8, 12]}, // Fixed range to prevent squashing
                        margin: {t:40, b:40, l:60, r:20},
                        hovermode: 'closest'
                    };

                    Plotly.newPlot(chartId, [trace], layout, {responsive:true, displayModeBar: false});
                    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
                    
                    controlsArea.innerHTML = `<div class="text-center text-gray-500 text-sm font-semibold py-2">🎉 Lektion erfolgreich abgeschlossen!</div>`;

                }, 1200);
            }
        }
        
        // Initial render trigger just in case
        setTimeout(() => {
            if(document.getElementById('tab-aufgabe').classList.contains('active')) renderCo2Chart();
        }, 100);
    </script>
</body>
</html>
